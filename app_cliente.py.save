def salvar_historico(dados):
    with open("historico_rwv.csv", "a", encoding="utf-8") as f:
        f.write(f"{dados['data']};{dados['cliente']};{dados['km']}km;R${dados['total']:.2f}\n")

# --- INTERFACE VISUAL (TRANSPARÊNCIA) ---

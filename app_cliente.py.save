st.markdown("### 📊 Simulador de Frete Transparente")

with st.form("orcamento"):
    nome = st.text_input("Seu Nome ou Empresa")
    whatsapp = st.text_input("Seu WhatsApp (com DDD)")
    origem = st.text_input("Ponto de Coleta (Rua/Bairro)")
    destino = st.text_input("Ponto de Entrega (Rua/Bairro)")
    km = st.number_input("Distância Prevista (KM)", min_value=0.5, step=0.1)

    # Lógica de Preço RWV
    base = 2.0 if km <= 10 else 5.0
    total = base + (km * 1.20)

    st.info(f"💡 Cálculo Transparente: Taxa R${base:.2f} + (KM {km} x R$1,20)")
    st.markdown(f"## *Total Estimado: R$ {total:.2f}*")
    
    enviar = st.form_submit_button("SOLICITAR LOGÍSTICA")

if enviar:
    if nome and whatsapp and origem and destino:
        agora = datetime.now().strftime("%d/%m/%Y %H:%M")
        
        # Salva no "Livro de Caixa" da Holding
        dados_corrida = {"data": agora, "cliente": nome, "km": km, "total": total}
